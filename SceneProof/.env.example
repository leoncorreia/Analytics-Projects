# SceneProof — copy to `SceneProof/.env` and/or `backend/.env` (backend file wins on duplicate keys).
APP_NAME=SceneProof API
DEBUG=false
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DATA_DIR=./data

# Force synthetic outputs even if keys are present
DEMO_MODE=false

# Seed 2.0 — reasoning, extraction, planning, validation
SEED2_API_KEY=
SEED2_BASE_URL=
SEED2_MODEL=seed-2.0

# Seedream 5.0 — storyboard / keyframes
SEEDREAM_API_KEY=
SEEDREAM_BASE_URL=
SEEDREAM_MODEL=seedream-5.0

# Seedance 2.0 — video clips
SEEDANCE_API_KEY=
SEEDANCE_BASE_URL=
SEEDANCE_MODEL=seedance-2.0

# Seed Speech — narration / TTS
SEED_SPEECH_API_KEY=
SEED_SPEECH_BASE_URL=
SEED_SPEECH_MODEL=seed-speech

# OmniHuman — presenter avatar clips
OMNIHUMAN_API_KEY=
OMNIHUMAN_BASE_URL=
OMNIHUMAN_MODEL=omnihuman

# --- Frontend (Vercel / CI only; not read by FastAPI) ---
# Set in Vercel → Project → Environment Variables → Production
# VITE_API_BASE_URL=https://YOUR-API.onrender.com
